.4)\n","fig2.update_traces(textinfo='percent+label')\n","\n","\n","fig3 = px.scatter(ventas_finales, x=\"precio\", y=\"venta_neta\", color=\"categoria\", size=\"cantidad\",\n","                  hover_name=\"producto\", hover_data=['canal', 'costo'])\n","\n","#Agregar Línea (Fila 1) y Torta (Fila 2)\n","fig_dashboard.add_trace(fig1.data[0], row=1, col=1)\n","\n","for trace in fig2.data:\n","    fig_dashboard.add_trace(trace, row=2, col=1)\n","\n","#Agregar el Scatter (Fila 3)\n","# Se guardaron los nombres de las categorías para armar el menú después\n","categorias_unicas = list(ventas_finales['categoria'].unique())\n","\n","for trace in fig3.data:\n","    fig_dashboard.add_trace(trace, row=3, col=1)\n","\n","#DROPDOWN\n","# Contar cuántos trazos tienen los primeros gráficos.\n","trazos_previos = 2\n","total_trazos_scatter = len(fig3.data)\n","\n","# Crear la lista de opciones para el menú (botones)\n","botones = []\n","\n","# Opción 1: Mostrar \"Todas\" las categorías\n","visibilidad_todas = [True] * trazos_previos + [True] * total_trazos_scatter\n","botones.append(dict(\n","    label=\"Todas las Categorías\",\n","    method=\"update\",\n","    args=[{\"visible\": visibilidad_todas}]\n","))\n","\n","# Opciones dinámicas: Una para cada categoría particular\n","for i, cat in enumerate(categorias_unicas):\n","    # Los gráficos 1 y 2 SIEMPRE quedan visibles (True).\n","    visibilidad_actual = [True] * trazos_previos + [False] * total_trazos_scatter\n","    visibilidad_actual[trazos_previos + i] = True\n","\n","    botones.append(dict(\n","        label=f\"Solo {cat}\",\n","        method=\"update\",\n","        args=[{\"visible\": visibilidad_actual}]\n","    ))\n","\n","#Configuración del diseño\n","fig_dashboard.update_layout(\n","    height=1300,\n","    title_text=\"Dashboard  Interactivo de Análisis de Ventas - Año 2024\",\n","    showlegend=True,\n","\n","    # Posición del menú Dropdown\n","    updatemenus=[dict(\n","        buttons=botones,\n","        direction=\"down\",\n","        showactive=True,\n","        x=0.0,       # Alineado a la izquierda\n","        y=0.33,      # Justo arriba del gráfico de dispersión (Fila 3)\n","        xanchor=\"left\",\n","        yanchor=\"bottom\"\n","    )]\n",")\n","# Títulos de los ejes para el Gráfico 1 (Fila 1, Columna 1)\n","fig_dashboard.update_xaxes(title_text=\"Mes\", row=1, col=1)\n","fig_dashboard.update_xaxes(tickmode='linear', tick0=1, dtick=1, row=1, col=1)\n","fig_dashboard.update_yaxes(title_text=\"Ventas Acumuladas ($)\", row=1, col=1)\n","\n","# Títulos de los ejes para el Gráfico 3 (Fila 3, Columna 1)\n","fig_dashboard.update_xaxes(title_text=\"Precio ($)\", row=3, col=1)\n","fig_dashboard.update_yaxes(title_text=\"Venta Neta ($)\", row=3, col=1)\n","\n","#Mostrar el dashboard\n","fig_dashboard.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"2n79zk9_C9AI","executionInfo":{"status":"ok","timestamp":1782498450844,"user_tz":180,"elapsed":799,"user":{"displayName":"Marisa Sandroni","userId":"03261408684484634374"}},"outputId":"96aa73bb-69f2-464a-80f3-dbccd19315f2"},"execution_count":91,"outputs":[{"output_type":"display_data","data":{"text/html":["<html>\n","<head><meta charset=\"utf-8\" /></head>\n","<body>\n","    <div>            <script src=\"https://cdnjs.cloudflare.com/ajax/libs/mathjax/2.7.5/MathJax.js?config=TeX-AMS-MML_SVG\"></script><script type=\"text/javascript\">if (window.MathJax && window.MathJax.Hub && window.MathJax.Hub.Config) {window.MathJax.Hub.Config({SVG: {font: \"STIX-Web\"}});}</script>                <script type=\"text/javascript\">window.PlotlyConfig = {MathJaxConfig: 'local'};</script>\n","        <script charset=\"utf-8\" src=\"https://cdn.plot.ly/plotly-2.35.2.min.js\"></script>                <div id=\"6f45ca9a-be16-4ec0-9e98-6c46d7c6d589\" class=\"plotly-graph-div\" style=\"height:1300px; width:100%;\"></div>            <script type=\"text/javascript\">                                    window.PLO